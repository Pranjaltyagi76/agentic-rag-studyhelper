mlflow.db
mlartifacts/
*.db
studyhelper.db
*.sqlite
# Trailing glob also catches SQLite's WAL sidecars (-wal, -shm, -journal),
# which "*.sqlite" does not match because of the suffix.
checkpoints.sqlite*
*.sqlite-wal
*.sqlite-shm

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json

# Pinned fastembed model cache (container uses /app/.fastembed)
.fastembed*/
