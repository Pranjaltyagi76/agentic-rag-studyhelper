# Copy to .env and fill in. Never commit the real .env.
# See deployment.md section 2 for the full reference.

# --- LLMs / tools ---
GROQ_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- Models (defaults shown; override if needed) ---
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OCR_MODEL=gemini-2.5-flash

# --- Vector store ---
# chroma = local dev; pgvector = deploy (Phase 9)
VECTOR_BACKEND=chroma
CHROMA_DIR=Chromadb
CHROMA_COLLECTION=Stuff

# --- Ingestion ---
UPLOAD_FOLDER=uploads
TAVILY_MAX_RESULTS=5

# --- Windows dev nicety: silence the HF symlink warning from fastembed's cache ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# --- Observability (LangSmith) — active from Phase 8 ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=studyhelper
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Persistence ---
# Leave DATABASE_URL unset for local dev — it defaults to a local SQLite file
# (sqlite:///./studyhelper.db), zero setup. Set it to Neon Postgres for deploy:
# DATABASE_URL=postgresql://<user>:<pass>@<neon-host>/<db>?sslmode=require
