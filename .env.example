# Copy to .env and fill in. Never commit the real .env.
# See deployment.md section 2 for the full reference.

# --- App / security ---
# development (default) exposes error details; production hides them AND refuses SQLite.
APP_ENV=development
# CORS: comma-separated allowed origins. "*" = any (dev). For deploy set your frontend
# origin(s), e.g. https://your-space.hf.space
CORS_ALLOW_ORIGINS=*
# Optional API-key gate: when set, every endpoint (except /health) requires this key via
# `X-API-Key` (or `Authorization: Bearer`). Leave empty for open local dev.
APP_API_KEY=

# --- LLMs / tools ---
GROQ_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- Models (defaults shown; override if needed) ---
GROQ_MODEL=llama-3.3-70b-versatile
# Grading model. Defaults to GROQ_MODEL: an 8B model was too lenient and broke
# abstention in the eval, so cost is saved via k-cap + grade truncation instead.
GRADER_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OCR_MODEL=gemini-2.5-flash

# --- Cost controls (keep one request affordable on the free token budget) ---
RETRIEVAL_K_CAP=15      # max chunks retrieved per attempt (planner may ask for more)
GRADE_CHUNK_CHARS=320   # only the first N chars of each chunk go to the grader

# --- Vector store ---
# chroma = local dev; pgvector = deploy (Phase 9)
VECTOR_BACKEND=chroma
CHROMA_DIR=Chromadb
CHROMA_COLLECTION=Stuff

# --- Ingestion ---
UPLOAD_FOLDER=uploads
TAVILY_MAX_RESULTS=5

# --- Windows dev nicety: silence the HF symlink warning from fastembed's cache ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# --- Observability (LangSmith): add your key to enable tracing (Phase 8) ---
# Tracing turns ON automatically once LANGCHAIN_API_KEY is filled; leave empty = off.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=studyhelper
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# OpenTelemetry (optional): OTLP endpoint to export FastAPI request spans
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Persistence ---
# Leave DATABASE_URL unset for local dev — it defaults to a local SQLite file
# (sqlite:///./studyhelper.db), zero setup. Set it to Neon Postgres for deploy:
# DATABASE_URL=postgresql://<user>:<pass>@<neon-host>/<db>?sslmode=require
